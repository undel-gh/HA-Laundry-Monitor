{
  "name": "HA Laundry Monitor",
  "image": "mcr.microsoft.com/devcontainers/python:3-3.14-bookworm",

  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install -r requirements_test.txt",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
